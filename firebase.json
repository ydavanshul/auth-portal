{
  "hosting": [
    {
      "target": "frontend",
      "public": "apps/frontend/out",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/api/**",
          "function": "api"
        }
      ]
    }
  ],
  "functions": {
    "source": "apps/backend",
    "predeploy": []
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
